# =============================================================================
# FundoCareer Backend — Environment Configuration (Example)
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env with real secrets to version control.
# =============================================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Production URLs ---
# For production, these must use https:// and the actual domain
FRONTEND_PUBLIC_URL='https://www.fundocareer.com'
BACKEND_PUBLIC_URL='https://your-backend-domain.com'
FRONTEND_URL='https://www.fundocareer.com'
VITE_URL='https://www.fundocareer.com'

# --- Database ---
DATABASE_URL="mysql://user:password@host:3306/fundo_v2"
DB_NAME=fundo_v2
DB_USER=root
DB_PASS=

# --- JWT Secret ---
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# --- Google OAuth (Web) ---
# Web client ID for Passport.js OAuth flow
GOOGLE_CLIENT_ID=your-web-client-id
# OAuth client secret — rotate immediately if exposed
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://www.fundocareer.com/api/auth/google/callback

# --- Google OAuth (Android native token verification) ---
# The Android app requests an ID token scoped to this Web Client ID
# Backend verifies the Android ID token against this value
GOOGLE_WEB_CLIENT_ID=your-web-client-id
# Android client ID (for documentation/reference only, not used by backend)
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id

# --- Mobile Auth ---
GOOGLE_MOBILE_CALLBACK_URL=https://www.fundocareer.com/api/mobile/auth/google/callback
ANDROID_DEEP_LINK_CALLBACK=fundocareer://auth/callback

# --- LinkedIn OAuth ---
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=https://www.fundocareer.com/api/auth/linkedin/callback

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=https://www.fundocareer.com/api/auth/github/callback

# --- Facebook OAuth ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRE=
FACEBOOK_CALLBACK_URL=https://www.fundocareer.com/api/auth/facebook/callback

# --- Cloudinary (image uploads) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- AI Services (at least one required) ---
# Xiaomi (Primary)
XIAOMI_API_KEY=your-xiaomi-api-key
# OpenRouter (Fallback)
OPENROUTER_API_KEY=your-openrouter-api-key
# Google Gemini (Final Fallback)
GEMINI_API_KEY=your-gemini-api-key
# Groq
GROQ_API_KEY=your-groq-api-key

# --- Razorpay ---
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# --- Email (Gmail SMTP with App Password) ---
# 🔴 CRITICAL: Gmail requires an App Password, NOT your regular Gmail password.
#    Your regular Gmail password will NOT work.
#    To set up:
#    1. Enable 2-Factor Authentication: https://myaccount.google.com/security
#    2. Generate App Password:         https://myaccount.google.com/apppasswords
#    3. Select "Mail" + your device name → generates 16 lowercase letters (e.g., abcd efgh ijkl mnop)
#    4. Remove spaces and paste below (exactly 16 lowercase letters with no spaces)
#    5. If the Gmail account is shared, each developer should generate their own App Password
SERVER_EMAIL_USERNAME=your-email@gmail.com
SERVER_EMAIL_PASSWORD=abcd efgh ijkl mnop
#                      ^-- remove spaces, exactly 16 lowercase letters

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- MongoDB ---
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=ujaf

# --- Feature Flags ---
FF_ENABLE_RESUME_BUILDER=true
ENABLE_ENTITLEMENT_CHECK=true
DEV_GUEST_MODE=true
BACKEND_BASE_URL=https://your-backend-domain.com
UJAF_AI_MODE=live
ALLOW_ANON_MAPPINGS=true
ALLOW_ALL_EMAIL_DOMAINS=false
UJAF_ENFORCE_DAILY_TOKEN_LIMIT=false
MAX_DAILY_AI_CALLS=50
AI_HTTP_TIMEOUT_MS=20000
AI_BATCH_HTTP_TIMEOUT_MS=20000
AI_BATCH_RETRY_TIMEOUT_MS=8000
AI_BATCH_CACHE_TTL_MS=604800000
AI_BATCH_CACHE_MAX=2000
AI_BATCH_MODEL_VERSION=mimo-v2-flash
AI_MAX_BATCH_Q=10
AI_FALLBACK_JOIN_IMMEDIATE=false
STORAGE_PROVIDER=local
DEBUG_EXTRACT=false
EXTRACTION_VERSION=2026-02-24-v2-repair-pass

# --- Other ---
ENABLE_ABANDONMENT_SWEEPER='true'
REDIRECT_URI=https://www.fundocareer.com/api/linkedin/callback
